# syntax=docker/dockerfile:1.7
#
# hermes-agent runtime image
# --------------------------
# Builds a single fat image containing every binary listed in catalog/binaries/.
# At `docker run` time the entrypoint reads BINARY_WHITELIST and exposes only
# those binaries on PATH (the rest stays quarantined under /opt/catalog/bin/).
#
# This implements approach (1) from docs/plans/2026-04-25-inkrement-5-...:
# one image to maintain, capability-flag mapping at run time enforces the
# minimum-required principle. Image bloat is the explicit trade-off.
#
# Build:
#   docker build -f Dockerfile.hermes-agent -t hermes-agent:dev .
# Run (smoke):
#   docker run --rm -e HERMES_HOME=/profile -e BINARY_WHITELIST="git,jq" \
#     hermes-agent:dev hermes --version

FROM node:22-bookworm-slim AS hermes-agent

# ------------------------------------------------------------------------------
# 1) Always-available base: shell + minimal coreutils + tini.
#    These stay on /usr/bin and /bin where the OS expects them. They are NOT
#    catalog binaries and are therefore not subject to the whitelist.
# ------------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates \
      bash \
      tini \
      gnupg \
    && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------------------
# 2) Install all catalog binaries into apt-managed locations, then move them
#    into a quarantine directory `/opt/catalog/bin/`. The entrypoint will only
#    expose whitelisted ones via symlinks into /usr/local/bin/.
#
#    Catalog inventory (synced with catalog/binaries/*.yml as of 2026-04-25):
#      curl, git, jq, python3, ripgrep (rg)         → from apt
#      gh                                           → from GitHub apt repo
#      yq                                           → upstream binary
#      node, pnpm                                   → already from base image
#      docker                                       → INTENTIONALLY NOT INSTALLED
#                                                     (docker-in-agent = host root;
#                                                      orchestrator-only concern)
# ------------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
      curl \
      git \
      jq \
      python3 \
      ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Add GitHub CLI apt repo (gh is not in Debian default repos)
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
       > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# yq (Mike Farah's Go implementation, not in apt)
ARG YQ_VERSION=v4.44.3
RUN ARCH="$(dpkg --print-architecture)" \
    && curl -fsSL "https://github.com/mikefarah/yq/releases/download/${YQ_VERSION}/yq_linux_${ARCH}" \
       -o /usr/local/bin/yq \
    && chmod +x /usr/local/bin/yq

# pnpm via corepack (node 22 ships with corepack)
RUN corepack enable && corepack prepare pnpm@latest --activate

# ------------------------------------------------------------------------------
# 3) Install Hermes Agent CLI.
#    MUST run BEFORE the quarantine step below — the upstream installer needs
#    curl, and quarantine relocates curl out of $PATH.
#
#    Hermes binary lands in /usr/local/bin/hermes by the upstream installer;
#    it is NOT a catalog binary and is therefore exempt from the whitelist —
#    it's the agent's own runtime, not a tool the agent uses.
#
#    `set -o pipefail` makes curl failures break the build instead of letting
#    bash silently succeed on empty input (caught a real regression once).
# ------------------------------------------------------------------------------
ARG HERMES_INSTALL_URL=https://hermes-agent.nousresearch.com/install.sh
# `--skip-setup` skips the interactive setup wizard, which would otherwise
# read from /dev/tty (unavailable during a Docker build). Run
# `hermes setup` later inside a live container if profile config is needed.
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
RUN curl -fsSL "$HERMES_INSTALL_URL" | bash -s -- --skip-setup
SHELL ["/bin/sh", "-c"]

# ------------------------------------------------------------------------------
# 4) Quarantine: move catalog binaries into /opt/catalog/bin/.
#    After this step, running e.g. `git` will fail with "command not found"
#    until the entrypoint symlinks it back based on BINARY_WHITELIST.
#
#    `node` is intentionally NOT quarantined: hermes itself may rely on a node
#    runtime, and node is also a catalog binary that we expose by default to
#    every agent. If we want to quarantine node later, we'd need a separate
#    "system node" inside hermes' install path.
# ------------------------------------------------------------------------------
RUN mkdir -p /opt/catalog/bin \
    && mv /usr/bin/curl     /opt/catalog/bin/curl \
    && mv /usr/bin/git      /opt/catalog/bin/git \
    && mv /usr/bin/jq       /opt/catalog/bin/jq \
    && mv /usr/bin/python3  /opt/catalog/bin/python3 \
    && mv /usr/bin/rg       /opt/catalog/bin/rg \
    && mv /usr/bin/gh       /opt/catalog/bin/gh \
    && mv /usr/local/bin/yq /opt/catalog/bin/yq \
    && cp "$(readlink -f "$(which pnpm)")" /opt/catalog/bin/pnpm \
    && cp "$(readlink -f "$(which node)")" /opt/catalog/bin/node

# ------------------------------------------------------------------------------
# 5) Profile mount point + entrypoint.
# ------------------------------------------------------------------------------
RUN mkdir -p /profile /workspace
COPY src/runners/hermes-agent-entrypoint.sh /usr/local/bin/hermes-agent-entrypoint
RUN chmod +x /usr/local/bin/hermes-agent-entrypoint

ENV HERMES_HOME=/profile \
    BINARY_WHITELIST=""

WORKDIR /workspace

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/hermes-agent-entrypoint"]
CMD ["hermes", "chat", "-q"]
