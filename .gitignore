.specifyr/
.DS_Store
node_modules/

# Local env file — contains secrets (TELEGRAM_BOT_TOKEN, ANTHROPIC_API_KEY, …).
# Use .env.example as the template. Never commit the real .env.
.env
.env.local

# Runtime user-data: spec-kit projects live under projects/<slug>/ at runtime.
# Each project is its own user-owned sandbox (its own .specify/, .claude/, etc.)
# and changes independently of specifyr's code. Tracking them produced 200+
# noise lines in `git status`. Test fixtures live under tests/fixtures/ — not
# here.
/projects/

# Build artefacts
.nuxt/
.output/

# Per-agent Hermes memory (runtime state, may contain credentials/sensitive context)
.hermes/

# Per-machine Claude settings (user-local overrides)
.claude/settings.local.json

# Local Docker Compose overrides (per-machine port/volume tweaks)
docker-compose.override.yml

# Runtime: installed extensions and their repos/node_modules
.specify/

# Temporary scratch directory
tmp/

# Playwright MCP browser cache
.playwright-mcp/

# Bundled local extensions: cloned at runtime by the Dockerfile prod stage,
# or by the dev manually for local work. Never tracked here.
/extensions/
