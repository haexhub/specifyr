# specifyr — local env file. Copy to `.env` and fill in real values.
#
# This file is read automatically by `docker compose` (when sitting next to
# the compose file). docker-compose.yml references these vars via
# `${VAR:-default}` substitution, then passes selected ones into the
# container via the `environment:` block.
#
# IMPORTANT: `.env` is gitignored. `.env.example` is committed as a template.
# Never put real secrets in `.env.example`.

# ─── Anthropic / Claude auth ──────────────────────────────────────────────
# Optional. If set, `claude` uses this key instead of OAuth login.
# If empty, the container reuses your host login via the ${HOME}/.claude
# bind-mount (see docker-compose.yml).
ANTHROPIC_API_KEY=

# ─── Hermes worker image ──────────────────────────────────────────────────
# Image tag used by hermes-docker.js to spawn agent containers.
# Dev default: locally-built `hermes-agent:dev`.
# Prod default: `ghcr.io/haexhub/hermes-agent:latest` (override with a
# pinned sha for reproducible deploys).
HERMES_AGENT_IMAGE=

# ─── Approval notification: Telegram ──────────────────────────────────────
# When BOTH TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID are set, the company
# runtime registers a Telegram transport. Agents that declare
# `approval.notify_via: ["telegram"]` will route approval requests to your
# chat with the bot.
#
# Setup (one-time, ~3 minutes):
#   1. Talk to @BotFather on Telegram, run /newbot, copy the bot token below.
#   2. Send any message to your new bot from your normal Telegram account.
#   3. Open
#        https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
#      in your browser. Find `"chat":{"id": ...}` in the JSON. That number
#      is your TELEGRAM_CHAT_ID.
#   4. Restart the company so the new env vars are picked up.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional. If set, Telegram messages embed a deep link
# `<APPROVAL_URL_BASE>/approvals/<requestId>` so you can tap from the phone
# straight into the approval UI.
#
# What value to use:
#   - localhost:3000              works only on the same machine
#   - http://<your-host>.local:3000   works on phone in same LAN (mDNS)
#   - http://192.168.x.y:3000     works on phone in same LAN (raw IP)
#   - https://<tunnel>.ngrok.app  works from anywhere via tunnel
#   - <leave empty>               notifications are info-only; open UI manually
APPROVAL_URL_BASE=

# ─── Database (Postgres, multi-tenant phase) ──────────────────────────────
# When set, the server connects to Postgres on boot, runs pending Drizzle
# migrations, and enables the multi-tenant features (users, orgs, llm
# credentials). Leave empty for the legacy single-user mode.
#
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
#
# Dev (Postgres läuft mit im docker-compose.yml als Service `postgres`):
#   - Aus dem specifyr-dev-Container: postgres://postgres:devpw@postgres:5432/specifyr
#   - Vom Host (psql/IDE):            postgres://postgres:devpw@localhost:${POSTGRES_PORT:-10001}/specifyr
DATABASE_URL=

# Master key for at-rest encryption of LLM credentials and per-project
# secrets. 64 hex chars (32 bytes). REQUIRED — docker compose will refuse
# to start both `specifyr` and `claude-proxy` without it.
#
# Generate (one-time):
#   openssl rand -hex 32
#
# Both `specifyr` and `claude-proxy` MUST see the identical value:
# specifyr writes encrypted oauth blobs into llm_credentials,
# claude-proxy reads + decrypts them at request time. A mismatch breaks
# every OAuth call with an opaque GCM-tag-mismatch error.
#
# Migrating an existing dev install: if you have `~/.specifyr/master.key`
# from a pre-2026-05 install, extract its hex form and paste below:
#   xxd -p ~/.specifyr/master.key | tr -d '\n' | cut -c1-64
# Otherwise existing encrypted rows become undecryptable.
#
# Production: comes from the `secrets.specifyr.secret_key` ansible value
# (renders into the container env). Never reuse the dev key in prod.
SPECIFYR_SECRET_KEY=

# Optional: override the connection string the claude-proxy uses to
# read llm_credentials. Defaults to the dev role provisioned by
# docker/postgres-init/03-create-haex-claude-proxy-role.sql. Set this
# only if you're pointing at a non-default Postgres or rotating the
# password.
PROXY_DATABASE_URL=

# ─── IDP / Auth ───────────────────────────────────────────────────────────
# Public URL of the Authentik instance. The frontend builds the logout
# redirect from this; if empty, the app falls back to dev-auth mode
# (cookie-based logout via /api/dev/logout) or single-user mode.
#
# Production: rendered automatically by the ansible specifyr role from
# `https://<authentik.sub_domain>.<domain>`.
# Local dev: leave empty.
AUTHENTIK_HOST=

# Local-dev shortcut: when set, the auth middleware synthesises a
# Remote-Email header for every request — you're "logged in as" this
# user without spinning up Authentik. Pair with /api/dev/{login,logout}
# to exercise the auth UI flow (Logout button only renders when this
# is set).
#
# DO NOT set in production. The /api/dev/* endpoints 404 unless this
# is configured, but it's still a footgun if AUTHENTIK_HOST is also
# unset on a public-facing instance.
#
# WICHTIG: Wenn du im dev-stack den Authentik-Multi-User-Flow testen willst,
# diese Variable LEER setzen — sonst überstimmt der env-fallback echte
# X-authentik-* Headers eines Forward-Auth-Proxys.
SPECIFYR_DEV_USER_EMAIL=

# Komma- oder Whitespace-separierte Liste an Emails, die beim user-upsert
# `is_platform_admin=true` bekommen (server/shared/middleware/auth.ts).
# Diese User sehen den "Platform admin"-Sidebar-Eintrag und können `/admin`
# öffnen. Im dev-stack reicht der Authentik-Bootstrap-User (akadmin@localhost).
SPECIFYR_PLATFORM_ADMIN_EMAILS=akadmin@localhost

# ─── Authentik (dev only, läuft im docker-compose.yml mit) ────────────────
# Image-Tag (siehe https://goauthentik.io/docs/releases). Default: 2024.10.
AUTHENTIK_IMAGE_TAG=

# 50+-Zeichen Geheimnis für Session-Signaturen. Generieren:
#   openssl rand -hex 32
# Dev-Default ist fest und unsicher — okay für localhost, NIEMALS in Prod.
AUTHENTIK_SECRET_KEY=

# Bootstrap-Admin: einmalig beim ersten Start angelegt. Login auf
# http://localhost:${AUTHENTIK_HTTP_PORT:-10002} als `akadmin` mit diesem Passwort.
AUTHENTIK_BOOTSTRAP_PASSWORD=
AUTHENTIK_BOOTSTRAP_TOKEN=
AUTHENTIK_BOOTSTRAP_EMAIL=

# ─── Host port scheme ─────────────────────────────────────────────────────
# Alle dev-Services laufen Host-seitig in einem zusammenhängenden Block ab
# PORT_BASE (Default 10000). Traefik bleibt auf 80 (Standard-HTTP, nicht
# umgezogen).
#
# Default-Belegung:
#   PORT_BASE+0 → specifyr            (container 3000)
#   PORT_BASE+1 → postgres            (container 5432)
#   PORT_BASE+2 → authentik http      (container 9000)
#   PORT_BASE+3 → authentik https     (container 9443)
#   PORT_BASE+4 → traefik dashboard   (container 8080)
#
# Compose kann in `${VAR}`-Substitution keine Arithmetik. `dev.sh` leitet
# deshalb die per-service-Vars aus PORT_BASE ab und exportiert sie vor
# `docker compose up`. Wer `docker compose` direkt aufruft, setzt entweder
# die per-service-Vars unten oder lebt mit den Defaults.
#
# Beispiele:
#   PORT_BASE=20000              # alles ab 20000 (dev.sh-Aufruf)
#   SPECIFYR_PORT=4242           # nur einen einzelnen Port pinnen
# PORT_BASE=
# SPECIFYR_PORT=
# POSTGRES_PORT=
# AUTHENTIK_HTTP_PORT=
# AUTHENTIK_HTTPS_PORT=
# TRAEFIK_DASHBOARD_PORT=

# ─── Docker Compose substitution helpers (advanced) ───────────────────────
# Host-side absolute path to this repo. Default uses `${PWD}`. Only override
# if specifyr runs natively on the host AND spawns docker sibling containers
# from a different path.
# SPECIFYR_HOST_PROJECT_ROOT=

# UID/GID mapping for bind-mounts on Linux. Override if your host user is
# not 1000:1000. macOS/Windows ignore these.
# UID=1000
# GID=1000
